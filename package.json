{
  "name": "api-gateway",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "gateway",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=gateway",
    "dev:services": "concurrently \"npm run dev --workspace=services/service-a\" \"npm run dev --workspace=services/service-b\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:services\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
