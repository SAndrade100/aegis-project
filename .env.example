# API Gateway — variáveis de ambiente
# Copie para .env e ajuste os valores

# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=seu-password-aqui
REDIS_DB=0

# ─── Auth ──────────────────────────────────────────────────────────────────
# OBRIGATÓRIO mudar em produção!
JWT_SECRET=dev-secret-change-in-production
API_KEY_HEADER=x-api-key

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100     # tokens por segundo por cliente
RATE_LIMIT_BURST=200       # capacidade máxima do bucket
RATE_LIMIT_WINDOW_MS=60000 # janela de 60s

# ─── Circuit Breaker ───────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5     # falhas para abrir o circuito
CB_SUCCESS_THRESHOLD=2     # sucessos em HALF_OPEN para fechar
CB_TIMEOUT_MS=10000        # tempo em OPEN antes de ir para HALF_OPEN
CB_HALF_OPEN_REQUESTS=3    # máximo de requests em HALF_OPEN

# ─── Proxy ─────────────────────────────────────────────────────────────────
PROXY_TIMEOUT_MS=30000

# ─── Consul ────────────────────────────────────────────────────────────────
CONSUL_HOST=localhost
CONSUL_PORT=8500

# ─── Observabilidade ───────────────────────────────────────────────────────
METRICS_PATH=/metrics
METRICS_PREFIX=api_gateway_
LOG_LEVEL=debug
